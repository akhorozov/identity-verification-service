{
  "Logging": {
    "LogLevel": {
      "Default": "Debug"
    }
  },
  "AddressValidation": {
    "Environment": "development",
    "EnableDetailedErrors": true
  },
  "Serilog": {
    "MinimumLevel": "Debug"
  },
  "OpenTelemetry": {
    "Tracing": {
      "Console": true
    },
    "Metrics": {
      "Console": true
    }
  },
  "AzureKeyVault": {
    "Enabled": false
  }
}
