{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "System": "Warning",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore.Mvc.Infrastructure": "Debug",
      "AddressValidation": "Debug"
    }
  },
  "AllowedHosts": "*",
  "AddressValidation": {
    "ApiVersion": "1.0",
    "CorrelationIdHeaderName": "X-Correlation-ID",
    "RequestIdHeaderName": "X-Request-ID",
    "EnableDetailedErrors": false,
    "ServiceName": "address-validation-proxy",
    "Environment": "development"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:o}] {Level:u3} {SourceContext,-40} {CorrelationId} - {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithCorrelationId"
    ],
    "Properties": {
      "Application": "AddressValidation.Api"
    }
  },
  "OpenTelemetry": {
    "Enabled": true,
    "Tracing": {
      "Enabled": true,
      "SamplingRatio": 1.0,
      "Console": false
    },
    "Metrics": {
      "Enabled": true,
      "Console": false
    }
  },
  "AzureKeyVault": {
    "Enabled": false,
    "VaultUri": "",
    "TenantId": "",
    "ClientId": ""
  },
  "Redis": {
    "Enabled": true,
    "ConnectionString": "localhost:6379",
    "DefaultDatabase": 0,
    "DefaultTtlSeconds": 3600,
    "EvictionPolicy": "allkeys-lru",
    "Ssl": false,
    "AbortOnConnectFail": true,
    "KeepAlive": 180,
    "ConnectTimeout": 5000,
    "SyncTimeout": 5000
  },
  "Cosmos": {
    "Enabled": true,
    "Endpoint": "https://localhost:8081/",
    "Key": "C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbiuNcWxNNJ6HIbtEve6b6IQ==",
    "DatabaseId": "address-validation-cache",
    "CacheContainerId": "validated-addresses",
    "PartitionKeyPath": "/pk",
    "DefaultTtlSeconds": 86400
  },
  "Validation": {
    "MaxBatchSize": 1000,
    "MaxRequestBodySizeInBytes": 10485760,
    "EnableValidatorCaching": true
  },
  "Cache": {
    "Ttl": 3600,
    "MaxAddressesPerBatch": 100,
    "EnableCaching": true
  },
  "Retry": {
    "MaxRetries": 3,
    "InitialDelayMs": 100,
    "MaxDelayMs": 5000,
    "BackoffMultiplier": 2.0
  },
  "Timeout": {
    "SingleAddressValidationMs": 30000,
    "BatchAddressValidationMs": 120000,
    "CacheOperationMs": 10000
  },
  "Security": {
    "ApiKeys": [
      {
        "Name": "default-readonly",
        "Key": "changeme-readonly-key",
        "Role": "readonly"
      },
      {
        "Name": "default-admin",
        "Key": "changeme-admin-key",
        "Role": "admin"
      }
    ],
    "RateLimiting": {
      "Enabled": true,
      "PermitLimit": 1000,
      "WindowSizeInSeconds": 60,
      "QueueLimit": 5
    },
    "Cors": {
      "AllowedOrigins": [ "https://localhost:7200", "https://localhost:3000" ],
      "AllowedMethods": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
      "AllowedHeaders": [ "Content-Type", "Authorization", "X-Correlation-ID" ],
      "AllowCredentials": false,
      "MaxAgeInSeconds": 3600
    },
    "SecurityHeaders": {
      "EnableHSTS": true,
      "EnableXContentTypeOptions": true,
      "EnableXFrameOptions": true,
      "EnableXXssProtection": true,
      "EnableReferrerPolicy": true
    }
  },
  "HealthChecks": {
    "Enabled": true,
    "Interval": 30,
    "Timeout": 5
  },
  "Metrics": {
    "PrometheusEnabled": true,
    "PrometheusPort": 9090,
    "PrometheusPath": "/metrics"
  },
  "Audit": {
    "Enabled": true,
    "LogToStorage": false,
    "StorageConnection": ""
  }
}
